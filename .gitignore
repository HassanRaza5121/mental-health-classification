artifacts/
outputs/
models/
*.h5
*.pt
*.joblib

# Data files (if you have any big dataset you don't want to push)
data/
*.csv
*.xlsx

# VS Code settings
.vscode/

# OS-specific files
.DS_Store
Thumbs.db

# GitHub / CI files (optional if storing local credentials)
.github/

# Python packaging / environment files
*.egg-info/
*.egg
dist/
build/

# Optional config / cache
__pycache__/
*.cache
*.pkl
*.zip

# Ignore personal environment files
*.env